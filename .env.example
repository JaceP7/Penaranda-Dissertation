# ── Geo-Agentic RAG — local development configuration ────────────────────────
# Copy this file to .env and fill in values.  .env is git-ignored (never commit it).
#
# Usage:
#   cp .env.example .env
#   # edit .env as needed
#   python wayfinding-app/serve_https.py
# ─────────────────────────────────────────────────────────────────────────────


# ── Ollama (default local LLM — no cloud, no limits) ─────────────────────────
# Leave as-is if Ollama is running on the same machine.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# To use a larger / faster model (if you pulled it):
# OLLAMA_MODEL=qwen2.5:7b
# OLLAMA_MODEL=llama3.2:3b

# To allow Ollama to handle multiple concurrent requests in parallel:
# Set this in a terminal BEFORE starting Ollama, not here:
#   $env:OLLAMA_NUM_PARALLEL=2; ollama serve      # PowerShell
#   OLLAMA_NUM_PARALLEL=2 ollama serve             # bash/WSL


# ── Cloud LLM options (one of two — Stage 5 only, embed/FAISS/rerank stay local)
# Priority: if both Groq and Gemini are enabled, Groq wins.
#
# ── Option A: Groq ───────────────────────────────────────────────────────────
# Fastest inference. Free tier: 14,400 RPD on small models.
# Get a key at: https://console.groq.com
#
# GROQ_API_KEY=gsk_...
# USE_GROQ=true
# GROQ_MODEL=qwen/qwen3-32b
#
# ── Option B: Google Gemini ──────────────────────────────────────────────────
# Excellent Filipino/Taglish quality. Free tier: 1,500 RPD on Gemini 2.5 Flash.
# No payment method required. Get a key at: https://aistudio.google.com
#
# GEMINI_API_KEY=AIza...
# USE_GEMINI=true
# GEMINI_MODEL=gemini-2.5-flash


# ── RAG tuning ────────────────────────────────────────────────────────────────
# Force the cross-encoder reranker to CPU even when CUDA is available:
# RAG_RERANKER_CPU=1
