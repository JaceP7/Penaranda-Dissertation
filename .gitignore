# ── SSL certificates & keys (NEVER commit private keys) ──────────────────────
*.pem
*.key
*.crt
*.csr

# ── mkcert binary ─────────────────────────────────────────────────────────────
*.exe

# ── Runtime server state (generated at runtime, not source) ───────────────────
wayfinding-app/app-state.json

# ── PDF files (binary blobs — dissertation drafts, compiled reports) ──────────
*.pdf

# ── Compiled LaTeX artefacts ──────────────────────────────────────────────────
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
*.bbl
*.blg
*.bcf
*.run.xml

# ── Claude Code internal files ────────────────────────────────────────────────
.claude/

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/

# ── Environment / secrets (NEVER commit — use .env.example as template) ───────
.env

# ── Query log (generated at runtime) ──────────────────────────────────────────
wayfinding-app/query_log.jsonl

# ── Git credential / auth artefacts (NEVER commit) ────────────────────────────
tmp_cred.txt
*.credentials

# ── Real (non-anonymized) floor plan — sensitive, not publicly available ──────
City Hall Floor Plan.pptx
City Hall Floor Plan/
# Annotated .drawio files that embed the real floor plan as base64 background
wayfinding-app/data/Floor_Slide*_Annotated*.drawio
dissertation/figures/Floor_Slide*_Annotated*.drawio
figures/Floor_Slide*_Annotated*.drawio
**/Floor_Slide*_Annotated*.drawio

# ── Extracted dissertation draft text (keep drafts out of git, like *.pdf) ────
_dissertation_ch1_2.txt
_instruments.txt

# ── Compiled Python ───────────────────────────────────────────────────────────
__pycache__/
*.pyc

# ── Local manual backups + exported runtime data (not source) ─────────────────
*.bak_*
*.bak
try.zip
pdr_walks_*.json
